          </TabsTrigger>
          <TabsTrigger value="billing" className="gap-2">
            <CreditCard size={16} />
            <span className="hidden md:inline">Billing</span>
          </TabsTrigger>
          <TabsTrigger value="security" className="gap-2">
            <Lock size={16} />
            <span className="hidden md:inline">Security</span>
          </TabsTrigger>
