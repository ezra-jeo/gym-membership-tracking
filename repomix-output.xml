@import 'swiper/css/pagination';

@custom-variant dark (&:is(.dark *));

:root {
  /* --- Stren Brand Colors --- */
  --color-primary:        #D4956A;
  --color-primary-light:  #E8B99A;
  --color-primary-dark:   #B5724A;
  --color-primary-glow:   rgba(212, 149, 106, 0.15);

  /* --- Neutrals --- */
  --color-charcoal:       #2C2C2C;
  --color-graphite:       #3D3D3D;
  --color-smoke:          #5A5A5A;
  --color-gray:           #8A8A8A;
  --color-light-gray:     #C4C4C4;
  --color-surface:        #F2EDE8;
  --color-background:     #FAF7F4;
  --color-white:          #FFFFFF;

  /* --- Semantic --- */
  --color-text-primary:   #1A1A1A;
  --color-text-secondary: #5A5A5A;
  --color-text-muted:     #8A8A8A;
  --color-text-inverse:   #FAF7F4;

  /* --- Status Colors --- */
  --color-success:        #4CAF7D;
  --color-success-bg:     rgba(76, 175, 125, 0.12);
  --color-danger:         #E05C5C;
  --color-danger-bg:      rgba(224, 92, 92, 0.12);
  --color-warning:        #E8A920;
  --color-warning-bg:     rgba(232, 169, 32, 0.12);

  /* --- Typography --- */
  --font-display:         'Playfair Display', serif;
  --font-heading:         'Syne', sans-serif;
  --font-body:            'Inter', sans-serif;

  /* --- Spacing --- */
  --space-1:  4px;
  --space-2:  8px;
  --space-3:  12px;
  --space-4:  16px;
  --space-6:  24px;
  --space-8:  32px;

  /* --- Radius --- */
  --radius-sm:   4px;
  --radius-md:   8px;
  --radius-lg:   16px;

  /* --- Type Scale (Landing) --- */
  --type-hero:        clamp(2.75rem, 5vw, 5rem);
  --type-hero-sub:    clamp(1.125rem, 1.5vw, 1.75rem);
  --type-section:     clamp(2rem, 3vw, 3rem);
  --type-body:        clamp(1rem, 1.1vw, 1.125rem);
  --type-label:       0.8125rem;
  --type-quote:       clamp(1.125rem, 1.4vw, 1.375rem);

  /* --- Additional Tokens --- */
