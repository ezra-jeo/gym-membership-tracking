                </div>
                <p className="mt-1 text-lg font-bold text-primary-foreground">
                  {"P" + methodBreakdown.gcashTotal.toLocaleString()}
                </p>
              </div>
            </div>
          </CardContent>
        </Card>
      </div>
    </div>
  )
}
