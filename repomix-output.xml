              <Button onClick={handleAddMember} className="w-full bg-primary hover:bg-primary/90">
                Add Member
              </Button>
            </div>
          </DialogContent>
        </Dialog>
      </div>

      {/* Filters */}
      <div className="flex flex-col md:flex-row gap-4">
