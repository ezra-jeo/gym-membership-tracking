          <Card className="p-6 space-y-6">
            <div>
              <h3 className="text-lg font-semibold text-foreground mb-4">Gym Information</h3>
              <div className="space-y-4">
                <div>
                  <Label htmlFor="gym-name">Gym Name</Label>
